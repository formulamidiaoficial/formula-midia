---
import "../styles/global.css";
import Meta from "../components/seo/Meta.astro";
import Schema from "../components/seo/Schema.astro";
import Nav from "../components/nav/Nav.astro";
import Footer from "../components/nav/Footer.astro";
import WhatsAppFloat from "../components/ui/WhatsAppFloat.astro";
import { organizationSchema } from "../data/schema";

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  noindex?: boolean;
  schema?: Record<string, any> | Record<string, any>[];
  /** Set true only on the homepage — avoids duplicating the Organization
   * schema on every single page. */
  includeOrganizationSchema?: boolean;
}

const {
  title,
  description,
  path,
  image,
  noindex = false,
  schema,
  includeOrganizationSchema = false,
} = Astro.props;

const schemaItems = [
  ...(includeOrganizationSchema ? [organizationSchema()] : []),
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : []),
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="theme-color" content="#E42929" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Fórmula Mídia" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="format-detection" content="email=no" />

    <Meta title={title} description={description} path={path} image={image} noindex={noindex} />
    {schemaItems.length > 0 && <Schema data={schemaItems} />}

    <link rel="icon" href="/assets/logo.png" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/logo.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
  </head>
  <body>
    <a href="#conteudo-principal" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-red focus:px-4 focus:py-2.5 focus:font-heading focus:text-sm focus:font-semibold focus:text-white">
      Pular para o conteúdo
    </a>
    <Nav />
    <main id="conteudo-principal">
      <slot />
    </main>
    <Footer />
    <WhatsAppFloat />
    <script src="/scripts/counter.js" is:inline defer></script>
  </body>
</html>
