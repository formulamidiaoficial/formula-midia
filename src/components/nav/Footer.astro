---
import { waLink } from "../../data/schema";

const columns = [
  {
    title: "Serviços",
    links: [
      { label: "Tráfego Pago", href: "/servicos" },
      { label: "Growth & Performance", href: "/growth" },
      { label: "Criação de Sites", href: "/criacao-de-sites" },
      { label: "SEO & GEO", href: "/seo" },
      { label: "Mentoria 1:1", href: "/mentoria" },
    ],
  },
  {
    title: "Ferramentas gratuitas",
    links: [
      { label: "Calculadora de escopo", href: "/calculadora" },
      { label: "Simulador de site", href: "/simulador-de-site" },
      { label: "Simulador de funil", href: "/simulador-de-funil" },
    ],
  },
  {
    title: "Quem atendemos",
    links: [
      { label: "Clínicas de alto padrão", href: "/segmentos/clinicas" },
      { label: "Imobiliárias & incorporação", href: "/segmentos/imobiliarias" },
      { label: "Hotelaria premium", href: "/segmentos/hotelaria" },
      { label: "Serviços de urgência", href: "/segmentos/servicos-de-urgencia" },
      { label: "Controle de pragas", href: "/segmentos/controle-de-pragas" },
    ],
  },
  {
    title: "Empresa",
    links: [
      { label: "O Manifesto", href: "/manifesto" },
      { label: "Todos os links", href: "/links" },
      { label: "Política de Privacidade", href: "/privacidade" },
      { label: "Termos de Uso", href: "/termos" },
    ],
  },
];
---

<footer class="border-t border-border px-6 py-14">
  <div class="mx-auto grid max-w-6xl gap-10 sm:grid-cols-2 lg:grid-cols-4">
    {columns.map((col) => (
      <div>
        <p class="mb-4 font-heading text-xs font-semibold uppercase tracking-[.08em] text-dim">{col.title}</p>
        <ul class="flex flex-col gap-2.5">
          {col.links.map((link) => (
            <li><a href={link.href} class="text-[13.5px] text-mid no-underline hover:text-ink">{link.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="mx-auto mt-12 max-w-6xl border-t border-border pt-6 text-center text-[12.5px] text-dim">
    <p>
      © {new Date().getFullYear()} Fórmula Mídia ·{" "}
      <a href="/" class="text-red-hi no-underline">formulamidia.com.br</a> ·{" "}
      <a href={waLink("Olá, quero saber mais sobre os serviços Fórmula Mídia")} target="_blank" rel="noopener" class="text-red-hi no-underline">
        WhatsApp
      </a>
    </p>
  </div>
</footer>
