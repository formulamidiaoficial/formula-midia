---
import BtnPrimary from "../ui/BtnPrimary.astro";
import HeroBlobs from "./HeroBlobs.astro";
import { waLink } from "../../data/schema";

interface Props {
  title: string;
  desc: string;
  message: string;
  ctaLabel?: string;
}

const { title, desc, message, ctaLabel = "Falar com especialista →" } = Astro.props;
---

<section class="relative overflow-hidden px-6 py-24 text-center">
  <HeroBlobs variant="bottom" />
  <div class="relative z-[2]">
    <h2 class="font-heading text-[clamp(26px,4vw,40px)] font-bold tracking-tight" data-in>{title}</h2>
    <p class="mx-auto mt-4.5 mb-9 max-w-[520px] text-base text-mid" data-in>{desc}</p>
    <BtnPrimary href={waLink(message)} target="_blank" rel="noopener">{ctaLabel}</BtnPrimary>
  </div>
</section>
