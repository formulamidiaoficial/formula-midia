---
// Zero-JS marquee: the logo list is duplicated once in markup so the
// CSS animation can loop seamlessly from -50% back to 0%.
const logos = Array.from({ length: 25 }, (_, i) => i + 1);
---

<div class="group relative overflow-hidden py-2 [mask-image:linear-gradient(90deg,transparent,black_10%,black_90%,transparent)]">
  <div class="flex w-max animate-[marquee_38s_linear_infinite] gap-14 group-hover:[animation-play-state:paused]">
    {[...logos, ...logos].map((n) => (
      <img
        src={`/assets/logos/${n}.png`}
        alt="Logo de cliente atendido pela Fórmula Mídia"
        class="h-9 w-auto shrink-0 object-contain opacity-50 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0"
        decoding="async"
      />
    ))}
  </div>
</div>

<style>
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-\[marquee_38s_linear_infinite\] { animation: none; }
  }
</style>
