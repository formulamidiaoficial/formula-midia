---
// Generic JSON-LD injector. Pass one schema.org object, or an array of them
// (each gets its own <script> tag, matching how multiple schema blocks
// coexist on a single page — e.g. LocalBusiness + FAQPage + BreadcrumbList).
interface Props {
  data: Record<string, any> | Record<string, any>[];
}

const { data } = Astro.props;
const items = Array.isArray(data) ? data : [data];
---

{items.map((item) => (
  <script type="application/ld+json" set:html={JSON.stringify(item)} />
))}
