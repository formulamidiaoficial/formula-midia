---
import BaseLayout from "../layouts/BaseLayout.astro";
import Badge from "../components/ui/Badge.astro";
import BtnPrimary from "../components/ui/BtnPrimary.astro";
import BtnGhost from "../components/ui/BtnGhost.astro";
import FaqAccordion from "../components/ui/FaqAccordion.astro";
import LogoCarousel from "../components/sections/LogoCarousel.astro";
import { waLink, faqPageSchema } from "../data/schema";
import { homeFaq } from "../data/faq/home";

const schema = faqPageSchema(homeFaq);

const platformFeatures = [
  {
    n: 1,
    title: "Dashboards Profissionais",
    desc: "Painéis exclusivos que mostram qual campanha, anúncio ou criativo gerou cada lead. Gestores de tráfego de alta performance utilizam essas ferramentas para otimizar campanhas de forma contínua.",
  },
  {
    n: 2,
    title: "Rastreamento via WhatsApp",
    desc: "Identificação da origem técnica de cada conversa iniciada no WhatsApp. Gestores de tráfego de alta performance utilizam essas ferramentas para otimizar campanhas de forma contínua.",
  },
  {
    n: 3,
    title: "CRM Visual com Kanban",
    desc: "Gestão visual dos leads e acompanhamento das etapas do processo comercial. Gestores de tráfego de alta performance utilizam essas ferramentas para otimizar campanhas de forma contínua.",
  },
  {
    n: 4,
    title: "Páginas de Conversão e SEO",
    desc: "Desenvolvimento de sites e landing pages de altíssima performance, com Lighthouse 90+ (muitos projetos com nota 100 em Performance, Acessibilidade, Boas Práticas e SEO). Construímos com stack moderna e IA (Claude Code e outras ferramentas), aplicando SEO técnico e GEO (otimização para mecanismos de busca por IA), para que tráfego pago e tráfego orgânico trabalhem juntos na geração de oportunidades de negócio.",
  },
  {
    n: 5,
    title: "Relatórios Automatizados",
    desc: "Relatórios periódicos enviados diretamente no WhatsApp com dados claros das campanhas. Gestores de tráfego de alta performance utilizam essas ferramentas para otimizar campanhas de forma contínua.",
  },
  {
    n: 6,
    title: "Otimização por Inteligência Artificial",
    desc: "Tecnologia que ajusta parâmetros técnicos das campanhas para manter eficiência do investimento.",
  },
  {
    n: 7,
    title: "Monitoramento de Instagram Orgânico",
    desc: "Acompanhe o desempenho do Instagram orgânico da empresa, visualizando métricas de alcance, engajamento e crescimento diretamente na plataforma.",
  },
  {
    n: 8,
    title: "Segurança de Dados",
    desc: "Infraestrutura com criptografia e conformidade com LGPD e GDPR.",
  },
];

const methodSteps = [
  { l: "M", t: "Mapeamento Estratégico", d: "Análise do negócio, mercado e oportunidades de investimento em tráfego pago." },
  { l: "I", t: "Implementação da Estrutura", d: "Configuração das plataformas de anúncios, rastreamento e integração das ferramentas." },
  { l: "D", t: "Desenvolvimento de Campanhas", d: "Criação e ativação das campanhas de anúncios com segmentação estratégica." },
  { l: "I", t: "Integração e Monitoramento", d: "Acompanhamento contínuo das campanhas e rastreamento do fluxo de leads." },
  { l: "A", t: "Análise de Dados e Escala", d: "Avaliação de resultados e identificação de oportunidades de crescimento." },
];

const differentials = [
  "Monitoramento contínuo das campanhas",
  "Clareza sobre a origem dos leads",
  "Dashboards profissionais de acompanhamento",
  "Integração com CRM e fluxo de atendimento",
  "Rastreamento técnico de campanhas",
  "Otimização contínua baseada em dados",
  "Infraestrutura tecnológica dedicada",
  "Gestão estruturada para escalabilidade",
];

const results = [
  { quote: "Redução de CPA de R$150 para R$45 em três meses de gestão.", segment: "Tecnologia" },
  { quote: "Estratégia comercial reestruturada com clareza de origem de cada lead.", segment: "Serviços B2B" },
  { quote: "Aumento de 280% nas conversões, com redução do custo por aquisição.", segment: "Varejo" },
];

const pricingTiers = [
  {
    name: "Fórmula Aceleração",
    desc: "Gestão profissional de tráfego pago com estrutura completa de geração de leads",
    feats: ["Gestão profissional de tráfego", "Google Ads ou Meta Ads", "Estruturação de campanhas", "Otimização semanal", "Estratégia de geração de leads", "Relatório mensal", "Dashboard exclusivo Fórmula Mídia", "Suporte estratégico"],
    note: "Gestão até R$5.000 de investimento em mídia. Acima disso, aplicar acréscimo de 5%.",
    featured: false,
  },
  {
    name: "Fórmula Conversão",
    desc: "Tudo do pacote anterior + CRM integrado para aumentar conversão e evitar perda de leads",
    feats: ["Tudo do Fórmula Aceleração", "CRM integrado ao WhatsApp", "Automação de atendimento", "Organização de leads", "Pipeline de vendas", "Funil de negociação", "Tracking completo do lead até a venda"],
    note: "Objetivo: aumentar a conversão e evitar perda de leads.",
    featured: true,
  },
  {
    name: "Fórmula Domínio",
    desc: "Solução completa com planejamento estratégico, funil de vendas e gestão criativa profissional",
    feats: ["Tudo do Fórmula Conversão", "Planejamento estratégico", "Estrutura de funil de vendas", "Criação de landing pages", "Campanhas de escala", "Otimização avançada de anúncios", "Gestão completa de criativos (cards, vídeos, fotos)", "Gestão criativa pela Essenzia"],
    note: "Solução completa para empresas que desejam dominar seu mercado.",
    featured: false,
  },
];

const comparisonRows = [
  { label: "Gestão de Tráfego", vals: [true, true, true] },
  { label: "Google Ads / Meta Ads", vals: [true, true, true] },
  { label: "CRM + WhatsApp", vals: [false, true, true] },
  { label: "Automação de Atendimento", vals: [false, true, true] },
  { label: "Planejamento Estratégico", vals: [false, false, true] },
  { label: "Landing Pages", vals: [false, false, true] },
  { label: "Gestão de Criativos", vals: [false, false, true] },
  { label: "Dashboard Exclusivo", vals: [true, true, true] },
];
---

<BaseLayout
  title="Fórmula Mídia | Crescimento para Negócios de Alto Padrão"
  description="A parceira de crescimento dos negócios de alto padrão da sua cidade — clínicas, imóveis, hotelaria e serviços premium. Transformamos reputação em fluxo constante de clientes."
  path="/"
  schema={schema}
  includeOrganizationSchema
>
  <!-- HERO -->
  <header class="relative overflow-hidden px-6 pb-20 pt-24 text-center">
    <div class="pointer-events-none absolute -left-32 -top-40 h-[460px] w-[460px] rounded-full bg-[radial-gradient(circle,rgba(228,41,41,.25),transparent_70%)] blur-[70px]"></div>
    <div class="pointer-events-none absolute -right-36 -top-20 h-[380px] w-[380px] rounded-full bg-[radial-gradient(circle,rgba(180,20,20,.20),transparent_70%)] blur-[70px]"></div>

    <div class="relative z-[2] mx-auto max-w-[820px]">
      <Badge label="Parceira de Crescimento" />
      <h1 class="mt-6 font-heading text-[clamp(32px,5.2vw,54px)] font-bold leading-[1.1] tracking-tight" data-in>
        Os melhores negócios da sua cidade merecem crescer como os melhores do mundo.
      </h1>
      <p class="mx-auto mt-5 max-w-[640px] text-[clamp(15px,1.6vw,18px)] leading-relaxed text-mid" data-in>
        Somos a parceira de crescimento dos negócios de alto padrão — clínicas, imóveis, hotelaria e serviços
        de urgência e alto valor. Transformamos a reputação que você já tem em fluxo constante de clientes.
      </p>
      <p class="mx-auto mt-4 max-w-[640px] text-[15px] leading-relaxed text-dim" data-in>
        Tráfego pago traz, CRM converte, dados otimizam — sob um único método de growth e um gestor de
        crescimento dedicado ao seu negócio.
      </p>
      <p class="mt-5 font-heading text-sm font-semibold text-red-hi" data-in>Reputação é o começo. Crescimento é o que fazemos.</p>

      <div class="mt-8 flex flex-wrap justify-center gap-3.5" data-in>
        <BtnPrimary href={waLink("Olá, quero saber como a Fórmula Mídia pode fazer meu negócio crescer")} target="_blank" rel="noopener">
          Quero crescer com método →
        </BtnPrimary>
        <BtnGhost href="#metodo">Ver como funciona</BtnGhost>
      </div>
      <p class="mt-4 text-xs text-dim" data-in>Diagnóstico de crescimento inicial.</p>

      <div class="mt-14 flex flex-wrap justify-center gap-x-14 gap-y-6" data-in>
        <div class="text-center"><div class="font-heading text-[28px] font-bold tracking-tight text-red-hi">100+</div><div class="mt-1 text-[11px] uppercase tracking-[.06em] text-dim">Clientes</div></div>
        <div class="text-center"><div class="font-heading text-[28px] font-bold tracking-tight text-red-hi">98%</div><div class="mt-1 text-[11px] uppercase tracking-[.06em] text-dim">Satisfação</div></div>
        <div class="text-center"><div class="font-heading text-[28px] font-bold tracking-tight text-red-hi">+10</div><div class="mt-1 text-[11px] uppercase tracking-[.06em] text-dim">Anos de experiência</div></div>
      </div>
    </div>
  </header>

  <!-- SEGMENTS -->
  <section class="border-y border-border px-6 py-8">
    <p class="mb-5 text-center text-xs font-semibold uppercase tracking-[.08em] text-dim">Negócios de alto padrão que crescem com a Fórmula Mídia</p>
    <div class="mx-auto flex max-w-[900px] flex-wrap items-center justify-center gap-x-3 gap-y-3">
      {["Clínicas premium", "Imobiliário & incorporação", "Hotelaria premium", "Serviços de urgência", "Alto valor local", "Controle de pragas"].map((seg) => (
        <span class="rounded-full border border-border bg-glass px-4 py-2 font-heading text-[13px] font-semibold text-mid">{seg}</span>
      ))}
    </div>
  </section>

  <!-- CLIENT LOGOS -->
  <section class="border-b border-border px-6 py-8">
    <p class="mb-6 text-center text-xs font-semibold uppercase tracking-[.08em] text-dim">Empresas que confiam na Fórmula Mídia</p>
    <LogoCarousel />
  </section>

  <!-- SERVICES HUB -->
  <section class="px-6 py-22">
    <div class="mx-auto max-w-[1080px]">
      <span class="mb-3.5 block font-heading text-xs font-semibold uppercase tracking-[.16em] text-red-hi" data-in>O motor de crescimento</span>
      <h2 class="max-w-[720px] font-heading text-[clamp(26px,3.4vw,38px)] font-bold leading-[1.15] tracking-tight" data-in>
        Growth é a espinha. Tráfego, sites e SEO são as peças que ela move.
      </h2>
      <p class="mt-5 max-w-[720px] text-[16px] leading-[1.75] text-mid" data-in>
        A maioria das agências entrega uma perna só. Nós integramos tudo sob um único método de crescimento —
        cada frente abaixo tem sua página, mas trabalham juntas pra encher a sua agenda.
      </p>

      <div class="mt-11 grid gap-5 md:grid-cols-2">
        {[
          { href: "/growth", tag: "A espinha", title: "Growth & Performance", desc: "Um gestor de crescimento e um método que integram tráfego, CRM e dados de ponta a ponta.", featured: true },
          { href: "/servicos", tag: "", title: "Tráfego Pago", desc: "Google Ads e Meta Ads com rastreamento real de leads e dashboards profissionais.", featured: false },
          { href: "/criacao-de-sites", tag: "", title: "Criação de Sites", desc: "Sites e landing pages de alta performance, Lighthouse 90-100, SEO técnico desde a fundação.", featured: false },
          { href: "/seo", tag: "", title: "SEO & GEO", desc: "Autoridade orgânica em buscadores tradicionais e mecanismos de busca por IA.", featured: false },
        ].map((s) => (
          <a
            href={s.href}
            class={`flex flex-col rounded-card border p-7 no-underline transition-all hover:-translate-y-1 ${s.featured ? "border-red/30 bg-gradient-to-b from-red/7 to-glass" : "border-border bg-glass hover:border-red/30"}`}
            data-in
          >
            {s.tag && <span class="mb-3 self-start rounded-full bg-red px-3 py-1 font-heading text-[10.5px] font-bold tracking-wide text-white">{s.tag}</span>}
            <h3 class="mb-2 font-heading text-lg font-bold text-ink">{s.title}</h3>
            <p class="mb-4 flex-1 text-sm leading-relaxed text-mid">{s.desc}</p>
            <span class="font-heading text-sm font-semibold text-red-hi">Saiba mais →</span>
          </a>
        ))}
      </div>

      <div class="mt-8 flex flex-wrap items-center gap-4 rounded-2xl border border-border bg-bg-2 px-6 py-5" data-in>
        <span class="font-heading text-sm font-semibold">Mentoria 1:1 com vagas limitadas por trimestre</span>
        <a href="/mentoria" class="font-heading text-sm font-semibold text-red-hi no-underline hover:underline">Ver detalhes →</a>
      </div>
    </div>
  </section>

  <!-- QUALIFIER -->
  <section class="section-light px-6 py-20">
    <div class="mx-auto max-w-[820px] text-center">
      <h2 class="font-heading text-[clamp(24px,3.2vw,34px)] font-bold tracking-tight" data-in>Isso é para o seu negócio?</h2>
      <p class="mt-4 text-base text-mid" data-in>Responda estas três perguntas e descubra se a Fórmula Mídia faz sentido para você.</p>

      <div class="mx-auto mt-10 flex max-w-[560px] flex-col gap-4 text-left">
        {[
          "Seu negócio já tem reputação e nome na cidade, mas ainda depende muito de indicação e boca a boca?",
          "Sente que poderia atender muito mais clientes se tivesse um fluxo previsível de novas oportunidades?",
          "Quer crescer com método e dados — não com achismo nem \"impulsionar\" post de vez em quando?",
        ].map((q) => (
          <div class="rounded-2xl border border-border bg-glass p-5 font-heading text-[15px] font-semibold" data-in>{q}</div>
        ))}
      </div>

      <p class="mt-8 text-base" data-in>Se suas respostas forem <strong>"sim"</strong>, a Fórmula Mídia faz sentido para você.</p>

      <div class="mx-auto mt-7 flex max-w-[560px] flex-col gap-2.5 text-left" data-in>
        {["Fluxo constante e previsível de novos clientes", "Reputação transformada em agenda cheia", "Crescimento acompanhado por dados, de ponta a ponta"].map((f) => (
          <div class="flex items-center gap-2.5 text-sm text-mid"><span class="font-bold text-red-hi">✓</span>{f}</div>
        ))}
      </div>

      <div class="mt-9">
        <BtnPrimary href={waLink("Quero transformar minha reputação em fluxo de clientes")} target="_blank" rel="noopener">Quero crescer com método</BtnPrimary>
      </div>
    </div>
  </section>

  <!-- PLATFORM -->
  <section id="plataforma" class="px-6 py-22">
    <div class="mx-auto max-w-[1080px]">
      <h2 class="max-w-[720px] font-heading text-[clamp(26px,3.4vw,38px)] font-bold leading-[1.15] tracking-tight" data-in>
        Uma plataforma completa de crescimento, não só de anúncios
      </h2>
      <div class="mt-5 flex max-w-[720px] flex-col gap-3 text-[16px] leading-[1.75] text-mid" data-in>
        <p>Disponibilizamos uma infraestrutura tecnológica completa que conecta cada etapa do crescimento do seu negócio — da primeira impressão do anúncio até o cliente fechando no WhatsApp.</p>
        <p>Anúncios de Google Ads e Meta Ads, dados, páginas de conversão e atendimento vivem em um único ambiente, sob um método de growth e um gestor dedicado.</p>
        <p>Assim você enxerga o caminho inteiro — do que trouxe o cliente até o que fechou a venda — com clareza e controle total sobre o crescimento.</p>
      </div>

      <div class="mt-12 grid auto-rows-[minmax(190px,auto)] grid-cols-1 gap-5 sm:grid-cols-2 md:grid-cols-4">
        <!-- Dashboards Profissionais: large cell with real product screenshot -->
        <div class="group relative col-span-1 overflow-hidden rounded-card border border-border sm:col-span-2 md:col-span-2 md:row-span-2" data-in>
          <img
            src="/assets/screenshots/dashboard-google-ads.png"
            alt="Dashboard real de campanhas Google Ads usado pela Fórmula Mídia"
            class="absolute inset-0 h-full w-full object-cover object-top opacity-35 transition-opacity duration-300 group-hover:opacity-55"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-bg via-bg/75 to-bg/10"></div>
          <div class="relative flex h-full flex-col justify-end p-6">
            <div class="mb-3 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-red/10 font-heading text-sm font-bold text-red-hi">{platformFeatures[0].n}</div>
            <h3 class="mb-1.5 font-heading text-[15.5px] font-semibold">{platformFeatures[0].title}</h3>
            <p class="max-w-md text-[13.5px] leading-relaxed text-mid">{platformFeatures[0].desc}</p>
          </div>
        </div>

        <!-- Relatórios Automatizados: tall cell with real WhatsApp report screenshot -->
        <div class="col-span-1 flex flex-col rounded-card border border-border bg-glass p-6 md:row-span-2" data-in>
          <div class="mb-3 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-red/10 font-heading text-sm font-bold text-red-hi">{platformFeatures[4].n}</div>
          <h3 class="mb-1.5 font-heading text-[15.5px] font-semibold">{platformFeatures[4].title}</h3>
          <p class="mb-4 text-[13.5px] leading-relaxed text-mid">{platformFeatures[4].desc}</p>
          <img
            src="/assets/screenshots/relatorio-whatsapp.png"
            alt="Exemplo real de relatório automático de campanhas enviado via WhatsApp"
            class="mt-auto max-h-56 w-full rounded-xl object-contain"
            loading="lazy"
            decoding="async"
          />
        </div>

        <!-- Rastreamento via WhatsApp: illustrative mockup, no real lead data -->
        <div class="col-span-1 flex flex-col rounded-card border border-border bg-glass p-6" data-in>
          <div class="mb-3 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-red/10 font-heading text-sm font-bold text-red-hi">{platformFeatures[1].n}</div>
          <h3 class="mb-1.5 font-heading text-[15.5px] font-semibold">{platformFeatures[1].title}</h3>
          <p class="mb-4 text-[13.5px] leading-relaxed text-mid">{platformFeatures[1].desc}</p>
          <div class="mt-auto flex flex-col gap-2">
            {[
              { label: "Novo lead recebido", time: "agora" },
              { label: "Contato via anúncio", time: "3 min" },
              { label: "Pedido de orçamento", time: "9 min" },
            ].map((row) => (
              <div class="flex items-center gap-2.5 rounded-xl border border-border bg-bg-2 px-3 py-2.5">
                <span class="h-2 w-2 shrink-0 rounded-full bg-emerald-400"></span>
                <p class="min-w-0 flex-1 truncate font-heading text-[12px] font-semibold">{row.label}</p>
                <span class="shrink-0 text-[10.5px] text-dim">{row.time}</span>
              </div>
            ))}
          </div>
        </div>

        {[2, 3, 5, 6, 7].map((i) => (
          <div class="flex gap-4 rounded-card border border-border bg-glass p-6" data-in>
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-red/10 font-heading text-sm font-bold text-red-hi">{platformFeatures[i].n}</div>
            <div>
              <h3 class="mb-1.5 font-heading text-[15.5px] font-semibold">{platformFeatures[i].title}</h3>
              <p class="text-[13.5px] leading-relaxed text-mid">{platformFeatures[i].desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- METHOD -->
  <section id="metodo" class="bg-bg-2 px-6 py-22">
    <div class="mx-auto max-w-[1080px]">
      <h2 class="max-w-[720px] font-heading text-[clamp(26px,3.4vw,38px)] font-bold leading-[1.15] tracking-tight" data-in>
        Método Fórmula Mídia®: o processo que transforma reputação em crescimento
      </h2>
      <p class="mt-5 max-w-[720px] text-[16px] leading-[1.75] text-mid" data-in>
        O Método Fórmula Mídia® organiza todo o crescimento do seu negócio em um processo estruturado que conecta
        estratégia, execução e dados. Cada etapa é desenhada para dar clareza sobre o investimento, controle da
        geração de clientes e capacidade de escalar — de negócios locais de alto padrão a operações em todo o Brasil.
      </p>

      <div class="mt-11 flex flex-col">
        {methodSteps.map((s, i, arr) => (
          <div class={`grid grid-cols-[52px_1fr] gap-5 border-t border-border py-6 ${i === arr.length - 1 ? "border-b" : ""}`} data-in>
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-red to-red-lo font-heading text-base font-bold text-white">{s.l}</div>
            <div>
              <h3 class="mb-1 font-heading text-[16px] font-semibold">{s.t}</h3>
              <p class="max-w-[560px] text-sm leading-relaxed text-mid">{s.d}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10">
        <BtnPrimary href={waLink("Vamos conversar sobre sua estratégia")} target="_blank" rel="noopener">Vamos conversar sobre sua estratégia</BtnPrimary>
      </div>
    </div>
  </section>

  <!-- DIFFERENTIALS -->
  <section id="diferenciais" class="px-6 py-22">
    <div class="mx-auto max-w-[1080px]">
      <h2 class="max-w-[720px] font-heading text-[clamp(24px,3.2vw,34px)] font-bold leading-[1.2] tracking-tight" data-in>
        Não fazemos apenas anúncios. Fazemos o seu negócio crescer.
      </h2>
      <p class="mt-5 max-w-[720px] text-[16px] leading-[1.75] text-mid" data-in>
        A Fórmula Mídia é a parceira de crescimento dos negócios de alto padrão. Integramos tráfego pago, CRM,
        SEO e dados sob um único método de growth — com um gestor de crescimento dedicado, conectando estratégia,
        tecnologia e acompanhamento contínuo para transformar reputação em fluxo constante de clientes.
      </p>

      <div class="mt-10 grid gap-3 sm:grid-cols-2">
        {differentials.map((d) => (
          <div class="flex items-center gap-2.5 rounded-xl border border-border bg-glass px-5 py-4 text-sm" data-in>
            <span class="font-bold text-red-hi">✓</span>{d}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section id="depoimentos" class="bg-bg-2 px-6 py-22">
    <div class="mx-auto max-w-[1080px]">
      <h2 class="max-w-[720px] font-heading text-[clamp(24px,3.2vw,34px)] font-bold tracking-tight" data-in>Resultados que já entregamos</h2>
      <p class="mt-4 max-w-[640px] text-base text-mid" data-in>Exemplos de resultados de negócios que transformaram reputação em crescimento com a Fórmula Mídia.</p>

      <div class="mt-11 grid gap-5 md:grid-cols-3">
        {results.map((r) => (
