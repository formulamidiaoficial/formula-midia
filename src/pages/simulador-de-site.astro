---
import BaseLayout from "../layouts/BaseLayout.astro";
import Badge from "../components/ui/Badge.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import SiteSimulator from "../components/islands/SiteSimulator.tsx";
import { breadcrumbSchema } from "../data/schema";

const breadcrumbItems = [
  { name: "Home", path: "/" },
  { name: "Criação de Sites", path: "/criacao-de-sites" },
  { name: "Simulador", path: "/simulador-de-site" },
];
const schema = breadcrumbSchema(breadcrumbItems);
---

<BaseLayout
  title="Simulador de Site | Fórmula Mídia"
  description="Simule seu site: escolha quantas páginas, se precisa de loja virtual e blog, e receba um resumo pronto para conversar com a gente."
  path="/simulador-de-site"
  schema={schema}
>
  <Breadcrumbs items={breadcrumbItems} />
  <header class="relative overflow-hidden px-6 pb-6 pt-16 text-center">
    <div class="pointer-events-none absolute -left-24 -top-44 h-[420px] w-[420px] rounded-full bg-[radial-gradient(circle,rgba(228,41,41,.22),transparent_70%)] blur-[80px]"></div>
    <div class="pointer-events-none absolute -right-28 -top-24 h-[380px] w-[380px] rounded-full bg-[radial-gradient(circle,rgba(180,20,20,.18),transparent_70%)] blur-[80px]"></div>

    <div class="relative z-[2] mx-auto max-w-[680px]">
      <a href="/criacao-de-sites" class="mb-6 inline-flex items-center gap-1.5 font-heading text-[13px] font-semibold text-mid no-underline hover:text-ink">← Voltar para Criação de Sites</a>
      <div class="mb-6"><Badge label="Simulador de Site" /></div>
      <h1 class="font-heading text-[clamp(28px,4.4vw,44px)] font-bold leading-[1.12] tracking-tight">
        Monte o escopo do <span class="text-red-hi">seu site</span>
      </h1>
      <p class="mx-auto mt-4 max-w-[520px] text-base leading-relaxed text-mid">
        Ajuste as opções abaixo e veja o resumo do seu projeto em tempo real.
      </p>
    </div>
  </header>

  <div class="section-light px-6 pb-24 pt-8">
    <div class="mx-auto max-w-[1140px]">
      <SiteSimulator client:load />
    </div>
  </div>
</BaseLayout>
