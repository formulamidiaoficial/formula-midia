# ============================================================
# FÓRMULA MÍDIA - .htaccess
# Segurança, Performance e SEO — site estático (Astro)
# ============================================================

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ============================================================
  # 1. FORÇAR HTTPS
  # ============================================================
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ============================================================
  # 2. BLOQUEAR ACESSO A ARQUIVOS SENSÍVEIS
  # ============================================================
  RewriteRule ^\.(env|git|htaccess|htpasswd)$ - [F]
  RewriteRule ^(admin|private|temp|upload)/ - [F]
  RewriteRule \.(env|lock|md)$ - [F]

  # ============================================================
  # 3. PROTEÇÃO CONTRA SQL INJECTION E XSS
  # ============================================================
  RewriteCond %{QUERY_STRING} (\<|%3C).*script.*\(|%3E) [NC,OR]
  RewriteCond %{QUERY_STRING} UNION.*SELECT [NC,OR]
  RewriteCond %{QUERY_STRING} union.*all.*select [NC]
  RewriteRule ^.* - [F,L]
</IfModule>

# ============================================================
# PÁGINA DE ERRO 404 CUSTOMIZADA
# ============================================================
ErrorDocument 404 /404.html

# ============================================================
# COMPRESSÃO GZIP
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/manifest+json
  AddOutputFilterByType DEFLATE font/opentype
  AddOutputFilterByType DEFLATE font/truetype
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ============================================================
# CACHE DO NAVEGADOR
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On

  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"

  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"

  ExpiresByType text/html "access plus 2 hours"
  ExpiresByType application/json "access plus 1 day"
  ExpiresByType application/manifest+json "access plus 1 day"

  ExpiresDefault "access plus 1 day"
</IfModule>

# ============================================================
# HEADERS DE SEGURANÇA
# ============================================================
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"

  # CSP mais restrita que a versão antiga nos pontos que dava — as fontes
  # agora são self-hospedadas (@fontsource), então não precisamos mais
  # liberar fonts.googleapis.com/fonts.gstatic.com nem https: genérico em
  # img-src. 'unsafe-inline' em script-src foi testado como necessário:
  # o Astro gera um pequeno script inline de bootstrap para hidratar os
  # componentes React (calculadora, simuladores) — sem isso, os
  # simuladores quebram em produção. Ao adicionar pixels de rastreamento
  # (Meta/GTM/GA4/LinkedIn) no futuro, adicionar os domínios exatos aqui —
  # nunca reabrir com um wildcard https:.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; base-uri 'self'; frame-ancestors 'self';"

  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header unset X-Powered-By
  Header always unset X-Powered-By
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ============================================================
# BLOQUEAR ACESSO DIRETO A DOTFILES
# ============================================================
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# ============================================================
# DESABILITAR LISTAGEM DE DIRETÓRIOS
# ============================================================
Options -Indexes

# ============================================================
# CHARSET PADRÃO
# ============================================================
AddDefaultCharset UTF-8
AddCharset UTF-8 .html .css .js .xml .json .rss .atom .webmanifest

# ============================================================
# TIPOS MIME ADICIONAIS
# ============================================================
AddType application/json .json
AddType application/manifest+json .webmanifest
AddType application/ld+json .jsonld
AddType application/xml .xml
AddType text/xml .xml
AddType image/svg+xml .svg
AddType font/ttf .ttf
AddType font/otf .otf
AddType font/woff .woff
AddType font/woff2 .woff2
